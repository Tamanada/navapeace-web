# Cloudflare Pages — HTTP response headers

# splash.html: never cache — Telegram WebView must always fetch fresh
/splash.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# HTML pages: revalidate on every request
/*.html
  Cache-Control: no-cache

# Static assets: cache 1 year (versioned via ?v= params)
/nasalization.woff
  Cache-Control: public, max-age=31536000, immutable

/logo.png
  Cache-Control: public, max-age=86400

/*.png
  Cache-Control: public, max-age=86400

/*.js
  Cache-Control: no-cache
